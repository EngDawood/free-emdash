---
import type { Locale } from "../../i18n/utils";
import { t } from "../../i18n/utils";

interface Project {
	id: string;
	data: {
		title?: string | null;
		summary?: string | null;
		year?: number | null;
		featured_image?: string | { src: string } | null;
		publishedAt?: Date | null;
	};
}

interface Props {
	locale: Locale;
	projects: Project[];
}

const { locale, projects } = Astro.props;
---

<section id="projects" class="projects reveal">
	<header class="section-header reveal-child">
		<h2 class="section-label">{t("projects.section", locale)}</h2>
		<h3 class="section-title">{t("projects.heading", locale)}</h3>
	</header>
	<div class="projects-grid">
		{projects.map((project, index) => (
			<a href={`/${locale}/work/${project.id}`} class="project-card reveal-item" style={`--delay: ${index}`}>
				{project.data.featured_image && (
					<div class="project-image">
						<img
							src={typeof project.data.featured_image === 'string'
								? project.data.featured_image
								: project.data.featured_image.src}
							alt={project.data.title ?? ''}
						/>
					</div>
				)}
				<div class="project-content">
					<div class="project-header">
						<h4 class="project-title">{project.data.title}</h4>
						<span class="project-arrow">↗</span>
					</div>
					<p class="project-summary">{project.data.summary}</p>
					<div class="project-meta">
						<span class="project-year">{project.data.year}</span>
					</div>
				</div>
			</a>
		))}
	</div>
	<div class="projects-cta">
		<a href={`/${locale}/work`} class="btn btn-secondary">
			{t("projects.viewAll", locale)} →
		</a>
	</div>
</section>

<style>
	.projects {
		padding: var(--spacing-4xl) var(--spacing-lg);
		max-width: var(--wide-width);
		margin: 0 auto;
		background: var(--color-bg-subtle);
	}

	.section-label {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		margin-bottom: var(--spacing-sm);
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 500;
		letter-spacing: var(--tracking-tight);
	}

	.section-header {
		margin-bottom: var(--spacing-2xl);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-xl);
	}

	.project-card {
		display: block;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		text-decoration: none;
		transition: all var(--transition-base);
	}

	.project-card:hover {
		border-color: var(--color-accent);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
		transform: translateY(-4px);
	}

	.project-image {
		aspect-ratio: 16/10;
		overflow: hidden;
	}

	.project-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--transition-slow);
	}

	.project-card:hover .project-image img {
		transform: scale(1.05);
	}

	.project-content {
		padding: var(--spacing-lg);
	}

	.project-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: var(--spacing-sm);
	}

	.project-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: 500;
	}

	.project-arrow {
		color: var(--color-muted);
		transition: all var(--transition-fast);
	}

	.project-card:hover .project-arrow {
		color: var(--color-accent);
		transform: translate(2px, -2px);
	}

	.project-summary {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		line-height: 1.6;
		margin-bottom: var(--spacing-md);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.project-meta {
		display: flex;
		justify-content: flex-end;
	}

	.project-year {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		font-family: var(--font-mono);
	}

	.projects-cta {
		margin-top: var(--spacing-2xl);
		text-align: center;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		font-size: var(--font-size-sm);
		font-weight: 500;
		border-radius: var(--radius);
		text-decoration: none;
		transition: all var(--transition-fast);
		cursor: pointer;
		border: none;
	}

	.btn-secondary {
		background: var(--color-surface);
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	@media (max-width: 1024px) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
